{
  "crons": [
    {
      "path": "/api/cron/daily-report",
      "schedule": "0 9 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
              "value": "script-src 'self' https://vercel.live *.vercel.live 'unsafe-inline' 'unsafe-eval' *.clerk.dev *.clerk.accounts.dev; worker-src blob:;"
        }
      ]
    }
  ]
}
